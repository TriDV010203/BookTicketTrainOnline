@model BookingTrain.Web.Models.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký – BookingTrain</title>
    <meta name="description" content="Tạo tài khoản BookingTrain và bắt đầu đặt vé tàu ngay hôm nay" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Extra for register – taller right panel */
        .auth-panel-right { align-items: flex-start; padding: 40px; overflow-y: auto; }
        .auth-form-box { padding: 24px 0; }
    </style>
</head>
<body class="auth-page">
    <div class="bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <div class="auth-split">
        <!-- ═══ LEFT PANEL ═══ -->
        <div class="auth-panel-left">
            <div class="auth-left-content">
                <a asp-controller="Home" asp-action="Index" class="auth-brand">
                    <div class="brand-icon">🚆</div>
                    <div class="brand-name">Booking<em>Train</em></div>
                </a>

                <h2>Tạo tài khoản<br/><span class="hl">miễn phí!</span></h2>
                <p>Chỉ mất 30 giây để đăng ký. Trải nghiệm đặt vé tàu nhanh chóng, tiện lợi và an toàn nhất Việt Nam.</p>

                <ul class="feat-list">
                    <li><div class="fi">🎁</div> Hoàn toàn miễn phí, không phí ẩn</li>
                    <li><div class="fi">⚡</div> Đặt vé chỉ trong 3 bước đơn giản</li>
                    <li><div class="fi">🛡️</div> Bảo mật thông tin người dùng</li>
                    <li><div class="fi">🔄</div> Đổi/hủy vé dễ dàng theo chính sách</li>
                    <li><div class="fi">📱</div> Xem vé ngay trên thiết bị di động</li>
                </ul>
            </div>
        </div>

        <!-- ═══ RIGHT PANEL ═══ -->
        <div class="auth-panel-right">
            <div class="auth-form-box">
                <div class="auth-form-header">
                    <a asp-controller="Home" asp-action="Index" class="mobile-brand">
                        <div class="brand-icon">🚆</div>
                        <div class="brand-name">Booking<em>Train</em></div>
                    </a>
                    <h1>Đăng ký tài khoản</h1>
                    <p>Điền thông tin bên dưới để tạo tài khoản mới</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-error">
                        <span class="alert-icon">⚠️</span>
                        <div>
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    </div>
                }

                <form asp-action="Register" method="post" id="register-form" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Họ tên -->
                    <div class="form-group">
                        <label class="form-label" for="name">Họ và tên</label>
                        <div class="input-wrap">
                            <span class="input-icon">👤</span>
                            <input type="text" id="name" name="Name"
                                   class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "input-error" : "")"
                                   value="@Model.Name"
                                   placeholder="Nguyễn Văn An"
                                   autocomplete="name" />
                        </div>
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "field-error" })
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <label class="form-label" for="email">Email</label>
                        <div class="input-wrap">
                            <span class="input-icon">📧</span>
                            <input type="email" id="email" name="Email"
                                   class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "input-error" : "")"
                                   value="@Model.Email"
                                   placeholder="ten@@email.com"
                                   autocomplete="email" />
                        </div>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                    </div>

                    <!-- Mật khẩu -->
                    <div class="form-group">
                        <label class="form-label" for="password">Mật khẩu</label>
                        <div class="input-wrap">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="password" name="Password"
                                   class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "input-error" : "")"
                                   placeholder="Tối thiểu 6 ký tự"
                                   autocomplete="new-password" />
                            <button type="button" class="pw-toggle" id="toggle-pw1">👁️</button>
                        </div>
                        <!-- Strength bars -->
                        <div class="strength-bars" id="strength-bars">
                            <div class="bar" id="b1"></div>
                            <div class="bar" id="b2"></div>
                            <div class="bar" id="b3"></div>
                            <div class="bar" id="b4"></div>
                            <div class="bar" id="b5"></div>
                        </div>
                        <div class="strength-text" id="strength-text"></div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                    </div>

                    <!-- Xác nhận mật khẩu -->
                    <div class="form-group">
                        <label class="form-label" for="confirmPassword">Xác nhận mật khẩu</label>
                        <div class="input-wrap">
                            <span class="input-icon">🔑</span>
                            <input type="password" id="confirmPassword" name="ConfirmPassword"
                                   class="form-control @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "input-error" : "")"
                                   placeholder="Nhập lại mật khẩu"
                                   autocomplete="new-password" />
                            <button type="button" class="pw-toggle" id="toggle-pw2">👁️</button>
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
                    </div>

                    <!-- Điều khoản -->
                    <div class="check-row" style="margin-bottom: 24px;">
                        <input type="checkbox" id="agree-terms" required />
                        <label for="agree-terms" style="font-size:.82rem;">
                            Tôi đồng ý với
                            <a href="#" style="color:var(--accent);">Điều khoản dịch vụ</a>
                            và
                            <a href="#" style="color:var(--accent);">Chính sách bảo mật</a>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-full btn-lg" id="register-btn">
                        🎉 Tạo tài khoản
                    </button>
                </form>

                <div class="auth-divider">đã có tài khoản?</div>

                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline btn-full">
                    🔑 Đăng nhập ngay
                </a>

                <div class="auth-footer" style="margin-top: 20px;">
                    Đã có tài khoản?
                    <a asp-controller="Auth" asp-action="Login">Đăng nhập →</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ── Toggle passwords ──
        function setupToggle(inputId, btnId) {
            const input = document.getElementById(inputId);
            const btn   = document.getElementById(btnId);
            if (!input || !btn) return;
            btn.addEventListener('click', () => {
                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                btn.textContent = show ? '🙈' : '👁️';
            });
        }
        setupToggle('password', 'toggle-pw1');
        setupToggle('confirmPassword', 'toggle-pw2');

        // ── Password strength ──
        const pwInput = document.getElementById('password');
        const bars    = [document.getElementById('b1'), document.getElementById('b2'),
                         document.getElementById('b3'), document.getElementById('b4'),
                         document.getElementById('b5')];
        const stText  = document.getElementById('strength-text');
        const colors  = ['', '#ef4444', '#f59e0b', '#eab308', '#3b82f6', '#10b981'];
        const labels  = ['', 'Rất yếu', 'Yếu', 'Trung bình', 'Mạnh', 'Rất mạnh'];

        function calcStrength(pw) {
            let s = 0;
            if (pw.length >= 6)  s++;
            if (pw.length >= 10) s++;
            if (/[A-Z]/.test(pw)) s++;
            if (/[0-9]/.test(pw)) s++;
            if (/[^a-zA-Z0-9]/.test(pw)) s++;
            return s;
        }
        pwInput && pwInput.addEventListener('input', () => {
            const score = calcStrength(pwInput.value);
            bars.forEach((b, i) => { b.style.background = i < score ? colors[score] : 'var(--border)'; });
            stText.textContent = pwInput.value ? labels[score] : '';
            stText.style.color = colors[score];
        });

        // ── Validate terms + loading ──
        const form = document.getElementById('register-form');
        const btn  = document.getElementById('register-btn');
        form.addEventListener('submit', (e) => {
            if (!document.getElementById('agree-terms').checked) {
                e.preventDefault();
                alert('Vui lòng đồng ý với Điều khoản dịch vụ để tiếp tục.');
                return;
            }
            btn.disabled = true;
            btn.innerHTML = '<span style="display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;"></span> Đang tạo tài khoản...';
        });
    </script>
    <style>@@keyframes spin { to { transform: rotate(360deg); } }</style>
</body>
</html>
